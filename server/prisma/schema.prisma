generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BUYER
  SELLER
  AGENT
  ADMIN
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum PropertyType {
  HOUSE
  APARTMENT
  PLOT
  COMMERCIAL
  FARMHOUSE
  OFFICE
  SHOP
}

enum PropertyPurpose {
  SALE
  RENT
}

enum AreaUnit {
  MARLA
  KANAL
  SQFT
  SQYD
}

enum ListingStatus {
  ACTIVE
  PENDING_VERIFICATION
  SOLD
  RENTED
  REJECTED
}

enum MessageType {
  TEXT
  IMAGE
  LOCATION
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PaymentMethod {
  JAZZCASH
  EASYPAISA
  CREDIT_CARD
}

model User {
  id               String             @id @default(uuid())
  email            String?            @unique
  phone            String             @unique
  passwordHash     String
  role             UserRole           @default(BUYER)
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  profile          Profile?
  verification     Verification?
  properties       Property[]
  favorites        Favorite[]
  sentMessages     Message[]          @relation("Sender")
  chats            ChatMember[]
  payments         Payment[]
  subscriptions    Subscription[]

  @@map("users")
}

model Profile {
  id             String   @id @default(uuid())
  userId         String   @unique
  fullName       String
  avatarUrl      String?
  bio            String?
  agencyName     String?
  agencyLicense  String?
  whatsappNumber String?
  isVerified     Boolean  @default(false)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Verification {
  id              String             @id @default(uuid())
  userId          String             @unique
  cnicNumber      String
  cnicFrontUrl    String
  cnicBackUrl     String
  documentUrl     String             // Ownership document
  status          VerificationStatus @default(PENDING)
  rejectionReason String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verifications")
}

model Property {
  id              String          @id @default(uuid())
  ownerId         String
  title           String
  description     String
  price           Decimal         @db.Decimal(15, 2)
  type            PropertyType
  purpose         PropertyPurpose
  status          ListingStatus   @default(PENDING_VERIFICATION)
  city            String
  area            String
  address         String
  latitude        Float?
  longitude       Float?
  areaSize        Float
  areaUnit        AreaUnit        @default(MARLA)
  bedrooms        Int?
  bathrooms       Int?
  parking         Int?            @default(0)
  amenities       String[]        // Array of features e.g. ["Gas", "Electricity", "Water"]
  videoUrl        String?
  viewCount       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  owner           User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  images          PropertyImage[]
  favorites       Favorite[]
  chats           Chat[]

  @@map("properties")
}

model PropertyImage {
  id         String   @id @default(uuid())
  propertyId String
  url        String
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_images")
}

model Favorite {
  id         String   @id @default(uuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@map("favorites")
}

model Chat {
  id         String       @id @default(uuid())
  propertyId String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  property   Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  members    ChatMember[]
  messages   Message[]

  @@map("chats")
}

model ChatMember {
  id             String   @id @default(uuid())
  chatId         String
  userId         String
  joinedAt       DateTime @default(now())
  chat           Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@map("chat_members")
}

model Message {
  id         String      @id @default(uuid())
  chatId     String
  senderId   String
  content    String
  type       MessageType @default(TEXT)
  createdAt  DateTime    @default(now())
  chat       Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender     User        @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Payment {
  id               String        @id @default(uuid())
  userId           String
  amount           Decimal       @db.Decimal(10, 2)
  status           PaymentStatus @default(PENDING)
  method           PaymentMethod
  gatewayReference String?
  description      String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Subscription {
  id        String   @id @default(uuid())
  userId    String
  planName  String   // e.g. "Featured Agency", "Premium Agent"
  amount    Decimal  @db.Decimal(10, 2)
  startDate DateTime @default(now())
  endDate   DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}
